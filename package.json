{
  "name": "knockout.game",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "cd database && bunx drizzle-kit generate",
    "db:push": "cd database && bunx drizzle-kit push",
    "db:browser": "cd database && bunx drizzle-kit studio",
    "start:server": "cd services/server && go run .",
    "cloc": "cloc . --exclude-dir=node_modules,dist,build,.next,.expo"
  },
  "dependencies": {
    "drizzle-orm": "^0.32.1",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.4",
    "typescript": "5.9.2",
    "drizzle-kit": "^0.23.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
